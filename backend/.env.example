# Server
PORT=3001
NODE_ENV=development

# Database (single common DB for web + apps)
DATABASE_URL=postgresql://anthar:anthar@localhost:5432/anthar_works

# Redis (queues, OTP rate limiting, caching)
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Payments — default for the admin "online payments" toggle. Set to false (or
# leave Razorpay keys blank) to run without Razorpay: customers place orders and
# staff mark them paid in the portal. Flip it live anytime from Portal > Settings.
PAYMENTS_ENABLED=true

# Razorpay (optional until you take online payments; the API boots without them)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# MSG91 (SMS / OTP, DLT-registered)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_OTP_TEMPLATE_ID=

# Meta WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_COMPANY_RECIPIENT=

# Firebase Cloud Messaging
FCM_SERVICE_ACCOUNT_JSON=

# Quick-start FAQ video pushed to customers on installation day
FAQ_VIDEO_URL=

# Object storage (MinIO locally / S3 or R2 in prod)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=anthar
S3_SECRET_KEY=anthar123
S3_BUCKET=anthar-media
